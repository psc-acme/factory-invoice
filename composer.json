{
    "name": "psc-acme/factory-invoice",
    "description": "Package factory-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\FactoryInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0",
        "brick/math": "^0.12",
        "symfony/filesystem": "^7.0",
        "league/flysystem": "^3.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "rector/rector": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}